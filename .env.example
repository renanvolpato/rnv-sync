APP_NAME="RNV Sync"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8770

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=rnvsync-app
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# RNV Sync
# Absolute path set by the installer. Left unset here so Laravel falls
# back to its default (database/database.sqlite) for plain dev clones —
# an empty value would break the SQLite connection.
# DB_DATABASE=
# In-app OAuth needs YOUR OWN Microsoft Entra app: the default (rclone
# public) id rejects RNV Sync's redirect_uri. See docs/oauth.md.
# Redirect URI to register: ${APP_URL}/oauth/callback
ONEDRIVE_CLIENT_ID=b15665d9-eda6-4092-8539-0eec376afd59
ONEDRIVE_CLIENT_SECRET=
# Identity endpoint: common (work+personal), consumers (personal
# OneDrive only — avoids guest sign-in into a work tenant),
# organizations or a tenant id/domain (work/school only).
ONEDRIVE_TENANT=common
RCLONE_MOUNT_BASE=${HOME}/RnvSync
# How often (minutes) a synced folder re-lists the whole remote to surface
# NEW cloud-side files as ☁ placeholders. The recursive listing is heavy on
# big drives, so it is throttled; "Sync now" forces an immediate refresh.
RNVSYNC_PLACEHOLDER_REFRESH_MINUTES=120
# Queue visibility timeout (seconds). Must stay ABOVE the longest job timeout
# (downloads / keep-online run up to 3600s) or a long job is retried while it
# is still running. Change only if you understand the impact.
DB_QUEUE_RETRY_AFTER=3900
# Best-effort "open a cloud file to download it" (physical model). Linux can't
# block the open to fetch content first (no Cloud Files API without FUSE), so
# the FIRST open of a not-yet-downloaded file still shows it empty; the
# download starts and the file becomes real shortly after — reopen to see it.
# Only a SINGLE placeholder opened at a time triggers it (a folder/thumbnailer
# scan that opens many at once is ignored, so your whole drive is never
# downloaded). Set to false to disable (right-click "Keep local" still works).
RNVSYNC_HYDRATE_ON_OPEN=true
REVERB_APP_ID=rnvsync
REVERB_APP_KEY=rnvsync-key
REVERB_APP_SECRET=rnvsync-secret
REVERB_HOST=localhost
REVERB_PORT=8771
REVERB_SCHEME=http

VITE_REVERB_APP_KEY=rnvsync-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8771
VITE_REVERB_SCHEME=http
